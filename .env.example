# BagsFuel Configuration
# Copy this file to .env and fill in your values

# Bags API Key — get from https://dev.bags.fm
BAGS_API_KEY=

# Solana RPC URL — use Helius, Quicknode, or public RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Your creator wallet private key (base58 encoded)
# WARNING: Keep this secret! Never commit your real key.
PRIVATE_KEY=

# Your token's mint address on Bags
TOKEN_MINT=

# SOL mint (don't change unless you know what you're doing)
SOL_MINT=So11111111111111111111111111111111111111112

# Growth cycle configuration
BUYBACK_PERCENT=30
REWARDS_PERCENT=20
TOP_HOLDERS_COUNT=25
MIN_CLAIM_THRESHOLD=100000000
SLIPPAGE_BPS=300
